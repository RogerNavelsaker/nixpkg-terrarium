{
  "name": "terrarium",
  "version": "0.1.0",
  "description": "CLI tool for graph analysis, designed for agents and tools.",
  "type": "module",
  "bin": {
    "tr": "./src/index.ts",
    "terrarium": "./src/index.ts"
  },
  "main": "src/index.ts",
  "files": [
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "bun2nix": "2.0.8"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "commander": "^15.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jayminwest/terrarium.git"
  },
  "homepage": "https://github.com/jayminwest/terrarium#readme",
  "bugs": {
    "url": "https://github.com/jayminwest/terrarium/issues"
  },
  "keywords": [
    "os-eco",
    "terrarium",
    "seeds",
    "cli",
    "graph"
  ],
  "scripts": {
    "show-manifest": "bun --eval \"console.log(await Bun.file('nix/package-manifest.json').text())\"",
    "sync:source": "bun run sync:github-release",
    "sync:github-source": "bun run scripts/sync-from-github-source.ts",
    "sync:github-release": "bun run scripts/sync-from-github-release.ts",
    "sync:npm": "bun run sync:npm-source",
    "sync:npm-source": "bun run scripts/sync-from-npm.ts",
    "postinstall": "bun x bun2nix -o bun.nix"
  }
}
